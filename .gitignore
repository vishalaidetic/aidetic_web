# ═══════════════════════════════════════════════════════════════════
#  .gitignore — covers Next.js frontend + FastAPI backend
# ═══════════════════════════════════════════════════════════════════

# ─── Environment / secrets ─────────────────────────────────────────
# Never commit real env files; only *.example files are tracked.
.env
.env.local
.env.backend
.env.development
.env.production
.env.test
.env.*.local
# Also cover nested backend env files
backend/.env
backend/backend/.env

# ─── Node / Next.js ────────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
tsconfig.tsbuildinfo

# ─── Python / FastAPI ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
.eggs/
*.egg
# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak
# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
*.cover
# MyPy
.mypy_cache/
.dmypy.json
dmypy.json
# Alembic generated revisions (optional — remove if you track migrations)
# backend/backend/alembic/versions/*.py

# ─── Database / data files ─────────────────────────────────────────
*.sqlite3
*.db
seed_log.txt
*.csv
*.sql.gz

# ─── Docker ────────────────────────────────────────────────────────
# Do not ignore docker-compose files — they are tracked
# Only ignore local overrides
docker-compose.override.yml
docker-compose.local.yml

# ─── OS artifacts ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ─── Miscellaneous ─────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
.cache/
coverage/
.turbo/

# ─── v0 / Vercel internal (if applicable) ──────────────────────────
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/