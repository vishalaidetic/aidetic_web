# Supabase Configuration
# Get these from your Supabase project: Settings → API

# Your Supabase project URL
# Example: https://project-name.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase public anon key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role key (KEEP THIS SECRET - only for server-side operations)
# Never commit this to version control
SUPABASE_SERVICE_ROLE_KEY=

# Admin Authentication (legacy token — kept for API routes)
# Generate a secure token for admin operations
# You can use: openssl rand -base64 32
ADMIN_TOKEN=your-secure-admin-token-here

# Admin Login (Supabase Auth)
# Create the admin user in: Supabase Dashboard → Authentication → Users → Add user
# The admin uses email + password to log in at /admin/login
# No additional env vars are needed — auth is handled via Supabase Auth sessions

# Site Configuration (Optional)
# Defaults to http://localhost:3000 for development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database Log Level (Optional)
# Set to 'debug' for verbose logs
DATABASE_LOG_LEVEL=info
