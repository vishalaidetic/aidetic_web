# ═══════════════════════════════════════════════════════════════════
#  .env.example  (Next.js / frontend)
#  Copy to .env.local and fill in real values.
#  This file is committed — DO NOT put real secrets here.
# ═══════════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin Auth ────────────────────────────────────────────────────
# Credentials used to log in to the admin dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Secret for signing the admin session cookie (keep this private)
# Generate: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ─── Admin Route ───────────────────────────────────────────────────
# UUID used to obfuscate the admin path (/admin/<uuid>/...)
# Generate: node -e "console.log(require('crypto').randomUUID())"
NEXT_PUBLIC_ADMIN_ROUTE_UUID=your-uuid-here

# A public token surfaced to the browser (legacy — used by some API routes)
NEXT_PUBLIC_ADMIN_TOKEN=your-secure-admin-token-here

# ─── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Database logging ──────────────────────────────────────────────
DATABASE_LOG_LEVEL=info

# ─── Brain (FastAPI) Backend ───────────────────────────────────────
# Server-side URL — used by Next.js API routes and Server Components.
# When running via docker compose this is automatically set to
# http://api-gateway:8000 by the compose file; only override here
# for local (non-Docker) development.
BRAIN_API_URL=http://localhost:8000

# Optional Bearer token if your FastAPI backend requires one
BRAIN_API_TOKEN=

# WebSocket URL accessible from the USER's browser.
# For local dev: ws://localhost:8000
# For production: wss://api.yourdomain.com
NEXT_PUBLIC_BRAIN_WS_URL=ws://localhost:8000
