# ═══════════════════════════════════════════════════════════════════
#  .env.backend.example
#  Copy to .env.backend and fill in real values.
#  This file is committed — DO NOT put real secrets here.
# ═══════════════════════════════════════════════════════════════════

# ─── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=brain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://postgres:postgres@db:5432/brain

# ─── Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── Kafka ─────────────────────────────────────────────────────────
KAFKA_SERVERS=kafka:9092

# ─── Chroma ────────────────────────────────────────────────────────
CHROMA_HOST=chromadb

# ─── AI / HuggingFace ──────────────────────────────────────────────
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
