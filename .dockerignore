# ─── Docker & build artifacts ───────────────────
Dockerfile
.dockerignore
.next
out

# ─── Dependencies (copied fresh inside Docker) ──
node_modules

# Exclude pnpm lockfile — Docker uses npm (package-lock.json)
# Without this, Next.js detects pnpm-lock.yaml and tries to invoke pnpm which is not installed
pnpm-lock.yaml

# ─── Version control ────────────────────────────
.git
.gitignore

# ─── Environment & secrets ──────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Dev tooling & docs ─────────────────────────
.vscode
.idea
README.md
SETUP.md
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS artifacts ───────────────────────────────
.DS_Store
Thumbs.db

# ─── TypeScript build cache ──────────────────────
tsconfig.tsbuildinfo
